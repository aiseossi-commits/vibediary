{
  "expo": {
    "name": "바다",
    "slug": "vibediary",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.aiseossi.vibediary",
      "buildNumber": "6",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "사진을 기록에 첨부하기 위해 카메라 접근이 필요합니다.",
        "NSMicrophoneUsageDescription": "음성 녹음을 위해 마이크 접근이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진을 기록에 첨부하기 위해 갤러리 접근이 필요합니다.",
        "NSUserNotificationUsageDescription": "기록 리마인더 알림을 보내기 위해 알림 권한이 필요합니다.",
        "LSSupportsOpeningDocumentsInPlace": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "VibeDiary Backup",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.json"
            ]
          }
        ]
      }
    },
    "android": {
      "backgroundColor": "#070D1A",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#070D1A"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "versionCode": 48,
      "package": "com.aiseossi.vibediary",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "content",
              "mimeType": "application/json"
            },
            {
              "scheme": "file",
              "mimeType": "application/json"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-av",
        {
          "microphonePermission": "음성 녹음을 위해 마이크 접근이 필요합니다."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "음성 녹음을 위해 마이크 접근이 필요합니다.",
          "speechRecognitionPermission": "음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다."
        }
      ],
      "expo-font",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070D1A"
        }
      ],
      "expo-secure-store",
      "expo-image",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0EA5A0",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "c43c1e17-f436-44d9-95ee-ed1cdad398b3"
      }
    },
    "owner": "aiseossi"
  }
}
